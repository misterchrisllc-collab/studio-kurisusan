# Copy to .env.local and fill in values from your Supabase project (Settings → API).
# Also add these in Vercel → Project → Settings → Environment Variables for production.

# Project URL, e.g. https://abcdefgh.supabase.co
NEXT_PUBLIC_SUPABASE_URL=

# Public anon key (safe to expose to the browser)
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service-role key (SECRET — server-only, used by the contact form server action)
SUPABASE_SERVICE_ROLE_KEY=
